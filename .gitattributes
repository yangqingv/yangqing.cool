# 自动检测文本文件
* text=auto

# 笔记文件强制 LF（跨平台兼容）
*.md text eol=lf

# TXT 文件强制 CRLF（Windows 原生格式）
*.txt text eol=crlf

# 配置文件强制 LF（跨平台兼容）
*.json text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# 脚本文件强制 LF（跨平台兼容）
*.sh text eol=lf
*.bat text eol=crlf

# 二进制文件不处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.exe binary
*.dll binary
*.ttf binary
*.otf binary